{
  "manifest_version": 3,
  "name": "Moje poznámky",
  "version": "1.0",
  "description": "Poznámky s ukládáním do JSON",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}